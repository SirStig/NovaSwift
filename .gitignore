# --- Copyrighted / user-supplied game data (NEVER commit) ---
# The base EV Nova game data is copyrighted. Contributors must supply their
# own legally-obtained copy. Only tooling and open reimplementation code lives
# in this repo.
data/base/**
!data/base/.gitkeep
data/plugins/**
!data/plugins/.gitkeep
data/converted/**
!data/converted/.gitkeep
assets/converted/**
!assets/converted/.gitkeep
# Full original game install (used locally for asset/data extraction reference)
data/EV Nova/

# --- Build artifacts ---
build/
DerivedData/
scratch-dd/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
.build/
*.o
*.a
*.dSYM/

# --- Xcode / macOS ---
.DS_Store
xcuserdata/
*.moved-aside
*.pbxuser
!default.pbxuser

# --- Third-party sources (vendored via scripts, not committed) ---
third_party/*/
!third_party/.gitkeep

# --- Node (extractor tooling, if used) ---
node_modules/
dist/

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
